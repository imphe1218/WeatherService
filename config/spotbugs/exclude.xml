<?xml version="1.0" encoding="UTF-8"?>

<FindBugsFilter>

    <!-- Ignore generated code only -->
    <Match>
        <Package name="org.weatherservice.generated"/>
    </Match>

    <Match>
        <Class name="org.weatherservice.controller.WeatherController"/>
        <Bug code="SECSC"/>
        <Bug pattern="SPRING_ENDPOINT"/>
    </Match>

    <Match>
        <Class name="org.weatherservice.service.CachedWeatherService"/>
        <Or>
            <Method name="logCacheHit"/>
            <Method name="logCacheRefresh"/>
            <Method name="logStaleCacheFallback"/>
            <Method name="logNoCacheFallback"/>
        </Or>
        <Bug pattern="CRLF_INJECTION_LOGS"/>
    </Match>

    <Match>
        <Class name="org.weatherservice.client.WeatherDownstreamClientImpl"/>
        <Or>
            <Method name="logProviderAttempt"/>
            <Method name="logProviderFailure"/>
        </Or>
        <Bug pattern="CRLF_INJECTION_LOGS"/>
    </Match>

    <!-- Keep default strict checking for everything else -->
    <!-- Do NOT suppress concurrency or constructor warnings globally -->


</FindBugsFilter>
