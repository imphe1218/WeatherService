<?xml version="1.0" encoding="UTF-8"?>

<FindBugsFilter>

    <!-- Ignore generated code only -->
    <Match>
        <Package name="org.weatherservice.generated"/>
    </Match>

    <Match>
        <Class name="org.weatherservice.controller.WeatherController"/>
        <Bug code="SECSC"/>
        <Bug pattern="SPRING_ENDPOINT"/>
    </Match>

    <!-- Keep default strict checking for everything else -->
    <!-- Do NOT suppress concurrency or constructor warnings globally -->


</FindBugsFilter>
